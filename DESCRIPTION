Package: RweaveExtra
Type: Package
Title: Sweave Drivers with Extra Tricks Up their Sleeves
Version: 1.3-1
Date: 2026-04-16
Authors@R: c(person("Vincent", "Goulet", role = c("cre", "aut"),
 	            email = "vincent.goulet@act.ulaval.ca",
		    comment = c(ORCID = "0000-0002-9315-5719")),
